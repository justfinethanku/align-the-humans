# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/qvzfcezbuzmvglgiolmh/settings/api

# Project URL (format: https://[project-ref].supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url

# Anon/Public Key (client-safe, used in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key (server-only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI generation now routes through OpenRouter (Vercel AI SDK + @openrouter/ai-sdk-provider)
# REQUIRED in production - powers all AI analysis/generation:
OPEN_ROUTER_API_KEY=your_openrouter_key
# Vercel AI Gateway key - used ONLY for the admin model-discovery list, not generation:
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key

# Email (Resend)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# App URL (used for email links)
# MUST be the production origin (e.g. https://alignthehumans.com) in
# production — auth emails (signup confirm, password reset, magic link)
# and partner invite emails all build absolute links from this value. If
# it's left unset or pointed at localhost, those links will 404 for real
# users.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Invite Token Encryption Secret
INVITE_TOKEN_SECRET=replace-with-a-long-random-string

# Supabase Auth Hook Secret (for email webhook verification)
SUPABASE_AUTH_HOOK_SECRET=your_auth_hook_secret
